  <div class="max-w-6xl mx-auto px-4 py-8 flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-sm">
      &copy; {currentYear} Precision Accounting. All rights reserved.
    </p>
    <div class="flex items-center gap-6">
      <a href="/privacy" class="text-sm hover:text-white transition-colors">
        Privacy Policy
      </a>
      <a href="/terms" class="text-sm hover:text-white transition-colors">
        Terms of Service
      </a>
    </div>
  </div>
</footer>
